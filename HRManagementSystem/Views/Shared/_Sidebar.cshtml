@using System.Security.Claims

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    //  Get Role
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value;
}

<aside class="sidebar">
    <div class="sidebar-header py-4 px-3">
        <a asp-controller="Home" asp-action="Index" class="d-block text-center text-decoration-none">
            <img src="~/images/logo.png" class="img-fluid sidebar-full-logo" style="max-height: 80px; max-width: 180px;">
            </a>
        </div>

        <nav class="sidebar-nav">
            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link @(controller == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                @if (userRole?.ToLower() == "superadmin" || userRole?.ToLower() == "admin")
                {
                    <li class="nav-item">
                        <a class="nav-link @(controller == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                            <i class="bi bi-person-badge"></i>
                            <span>Users</span>
                        </a>
                    </li>
                }
            </li>
            

            <!-- Employees -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span>Employees</span>
                </a>
            </li>

            <!-- Departments -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Department" ? "active" : "")" asp-controller="Department" asp-action="Index">
                    <i class="bi bi-building"></i>
                    <span>Departments</span>
                </a>
            </li>

            <!-- Attendance -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Attendance" ? "active" : "")" asp-controller="Attendance" asp-action="Index">
                    <i class="bi bi-calendar-check"></i>
                    <span>Attendance</span>
                </a>
            </li>

            <!-- Payroll -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Payroll" ? "active" : "")" asp-controller="Payroll" asp-action="Index">
                    <i class="bi bi-bank"></i>
                    <span>Payroll</span>
                </a>
            </li>

            <!-- Appraisal -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Appraisal" ? "active" : "")" asp-controller="Appraisal" asp-action="Index">
                    <i class="bi bi-graph-up"></i>
                    <span>Appraisal</span>
                </a>
            </li>

            <!-- Reimbursement -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Reimbursement" ? "active" : "")" asp-controller="Reimbursement" asp-action="Index">
                    <i class="bi bi-cash-stack"></i>
                    <span>Reimbursement</span>
                </a>
            </li>

            <!-- Tasks -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Tasks" ? "active" : "")" asp-controller="Tasks" asp-action="Index">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Tasks</span>
                </a>
            </li>

            <!--  Roles (Only SuperAdmin) -->
            @if (userRole == "SuperAdmin")
            {
                <li class="nav-item">
                    <a class="nav-link @(controller == "Roles" ? "active" : "")" asp-controller="Roles" asp-action="Index">
                        <i class="bi bi-shield-lock"></i>
                        <span>Roles & Permissions</span>
                    </a>
                </li>
            }

            <!-- Documents -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Documents" ? "active" : "")" asp-controller="Documents" asp-action="Index">
                    <i class="bi bi-folder2-open"></i>
                    <span>Documents</span>
                </a>
            </li>

            <!-- Holidays -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Holidays" ? "active" : "")" asp-controller="Holidays" asp-action="Index">
                    <i class="bi bi-calendar-heart"></i>
                    <span>Holiday Calendar</span>
                </a>
            </li>

            <!-- Settings -->
            <li class="nav-item">
                <a class="nav-link @(controller == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-gear"></i>
                    <span>Settings</span>
                </a>
            </li>

        </ul>
    </nav>

    <div class="mt-auto p-3">
        <a class="nav-link text-danger border-top pt-3 mt-2" asp-controller="Auth" asp-action="Logout">
            <i class="bi bi-box-arrow-right"></i>
            <span>Logout</span>
        </a>
    </div>
</aside>