@{
    ViewData["Title"] = "Add Department";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Add Department</h1>
            <p class="page-subtitle">Define a new organizational unit</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">Create Department</button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-12 mb-3">
                    <label class="form-label small fw-bold">Department Name</label>
                    <input type="text" class="form-control" placeholder="e.g. Quality Assurance">
                </div>
                <div class="col-md-12">
                    <label class="form-label small fw-bold">Department Manager</label>
                    <select class="form-select">
                        <option>Search Manager...</option>
                        <option>Dhaval Patel</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</form>