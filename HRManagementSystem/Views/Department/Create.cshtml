@model CrudOperation_1.Models.Department

@{
    ViewData["Title"] = "Create Department";
}

<div class="container-fluid">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="fw-bold text-primary">
            <i class="bi bi-building-add"></i> Create Department
        </h3>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>

    </div>

    <!-- Card -->
    <div class="row justify-content-center">

        <div class="col-lg-5">

            <div class="card shadow-sm border-0">

                <div class="card-body p-4">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Department Name -->
                        <div class="mb-3">

                            <label asp-for="DepartmentName" class="form-label fw-semibold"></label>

                            <input asp-for="DepartmentName" class="form-control" placeholder="Enter department name" />

                            <span asp-validation-for="DepartmentName" class="text-danger"></span>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}