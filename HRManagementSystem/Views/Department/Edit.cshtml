@model HRManagementSystem.Models.Department

@{
    ViewData["Title"] = "Edit Department";
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Dept_Id" />

    <div class="page-header border-bottom pb-4 mb-4">
        <div>
            <h1 class="page-title">Edit Department</h1>
            <div class="breadcrumb-container">
                <div class="page-breadcrumb">
                    <a href="/">Dashboard</a> / <a asp-action="Index">Departments</a> / <span class="text-dark fw-medium">Edit Department</span>
                </div>
            </div>
            <p class="page-subtitle mt-2 mb-0">Update details for @Model.DepartmentName</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">Update Department</button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-12 mb-3">
                    <label asp-for="DepartmentName" class="form-label small fw-bold">Department Name</label>
                    <input asp-for="DepartmentName" class="form-control" placeholder="e.g. Quality Assurance">
                    <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}