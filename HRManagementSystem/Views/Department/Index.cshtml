@model IEnumerable<HRManagementSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Departments</h1>
        <p class="page-subtitle">Manage organizational departments</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-building-add me-2"></i> Add Department
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="card-header bg-white py-3 border-bottom-0">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="card-title">Department List</h5>
            </div>
            <div class="col-auto">
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="deptSearch" class="form-control bg-light border-start-0" placeholder="Search departments..." onkeyup="filterDeptTable()">
                </div>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="deptTable">
            <thead>
                <tr>
                    <th>Department Name</th>
                    <th>Manager</th>
                    <th class="text-center-align">Total Employees</th>
                    <th>Created Date</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light text-primary rounded-pill d-flex align-items-center justify-content-center me-3" style="width: 38px; height: 38px;">
                                    <i class="bi bi-building"></i>
                                </div>
                                <div class="fw-bold text-dark">@item.DepartmentName</div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center me-2 small fw-bold" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                    M
                                </div>
                                <span class="text-muted small">Not Assigned</span>
                            </div>
                        </td>
                        <td class="text-center-align">
                            <span class="px-2 py-1 bg-light border rounded-pill small fw-medium">0</span>
                        </td>
                        <td>
                            <span class="text-muted small">@DateTime.Now.ToString("dd MMM yyyy")</span>
                        </td>
                        <td class="actions-column">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Dept_Id" class="btn btn-sm btn-outline-light text-primary border" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" onclick="confirmDelete('@Url.Action("Delete", "Department", new { id = item.Dept_Id })', 'Department')" class="btn btn-sm btn-outline-light text-danger border" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterDeptTable() {
            var input = document.getElementById("deptSearch").value.toLowerCase();
            var table = document.getElementById("deptTable");
            var rows = table.getElementsByTagName("tr");

            for (var i = 1; i < rows.length; i++) {
                var text = rows[i].cells[0].textContent.toLowerCase();
                rows[i].style.display = text.includes(input) ? "" : "none";
            }
        }
    </script>
}