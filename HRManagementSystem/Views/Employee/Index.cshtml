@model List<HRManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Employees</h1>
        <p class="page-subtitle">Manage employee records efficiently</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus me-2"></i> Add Employee
        </a>
    </div>
</div>

<div class="card mb-4 overflow-hidden border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <!-- Filters Area -->
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="employeeSearch" class="form-control border-start-0" placeholder="Search by name or ID..." onkeyup="filterTable()">
                </div>
            </div>
            <div class="col-md-3">
                <select id="deptFilter" class="form-select" onchange="filterTable()">
                    <option value="">All Departments</option>
                    @foreach (var dept in Model.Select(e => e.Department?.DepartmentName).Distinct().Where(d => d != null))
                    {
                        <option value="@dept">@dept</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select id="statusFilter" class="form-select" onchange="filterTable()">
                    <option value="">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
            <div class="col-md-1 text-end">
                <button class="btn btn-outline-secondary" onclick="resetFilters()" title="Reset Filters">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="employeeTable">
            <thead>
                <tr>
                    <th>Employee Name</th>
                    <th class="text-center-align">Employee ID</th>
                    <th>Department</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joining Date</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(emp.Emp_Image))
                                {
                                    <img src="@emp.Emp_Image" class="rounded-circle me-3" width="40" height="40" style="object-fit: cover; border: 2px solid #f1f5f9;" />
                                }
                                else
                                {
                                    <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 40px; height: 40px; border: 2px solid #f1f5f9;">
                                        @emp.Emp_Name.Substring(0, 1)
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold text-dark">@emp.Emp_Name</div>
                                    <div class="small text-muted">@emp.Emp_Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-center-align">
                            <span class="badge bg-light text-dark fw-normal border">#@emp.Emp_Id</span>
                        </td>
                        <td>
                            <span class="text-dark">@(emp.Department?.DepartmentName ?? "N/A")</span>
                        </td>
                        <td>
                            <span class="text-muted">Staff</span> <!-- Placeholder Role -->
                        </td>
                        <td>
                            @if (emp.Emp_Status)
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <span class="text-muted small">01 Jan 2024</span> <!-- Placeholder Joining Date -->
                        </td>
                        <td class="actions-column">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@emp.Emp_Id" class="btn btn-sm btn-outline-light text-primary border" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" onclick="confirmDelete('@Url.Action("Delete", "Employee", new { id = emp.Emp_Id })', 'Employee')" class="btn btn-sm btn-outline-light text-danger border" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            var searchInput = document.getElementById("employeeSearch").value.toLowerCase();
            var deptFilter = document.getElementById("deptFilter").value;
            var statusFilter = document.getElementById("statusFilter").value;
            
            var table = document.getElementById("employeeTable");
            var rows = table.getElementsByTagName("tr");

            for (var i = 1; i < rows.length; i++) {
                var nameText = rows[i].cells[0].textContent.toLowerCase();
                var idText = rows[i].cells[1].textContent.toLowerCase();
                var deptText = rows[i].cells[2].textContent;
                var statusText = rows[i].cells[4].textContent;
                
                var matchesSearch = nameText.includes(searchInput) || idText.includes(searchInput);
                var matchesDept = deptFilter === "" || deptText.includes(deptFilter);
                var matchesStatus = statusFilter === "" || statusText.trim() === statusFilter;

                if (matchesSearch && matchesDept && matchesStatus) {
                    rows[i].style.display = "";
                } else {
                    rows[i].style.display = "none";
                }
            }
        }

        function resetFilters() {
            document.getElementById("employeeSearch").value = "";
            document.getElementById("deptFilter").value = "";
            document.getElementById("statusFilter").value = "";
            filterTable();
        }
    </script>
}