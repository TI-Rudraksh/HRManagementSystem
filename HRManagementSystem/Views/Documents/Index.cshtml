@{
    ViewData["Title"] = "Employee Documents";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Employee Documents</h1>
        <p class="page-subtitle">Manage uploaded employee records</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-upload me-2"></i> Upload Document
        </a>
    </div>
</div>

<div class="card mb-4 border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-5">
                <select class="form-select">
                    <option value="">All Document Types</option>
                    <option>Identity Proof</option>
                    <option>Education Certificate</option>
                    <option>Experience Letter</option>
                </select>
            </div>
            <div class="col-md-5">
                <select class="form-select">
                    <option value="">All Departments</option>
                    <option>IT</option>
                    <option>HR</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100">Search</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Employee Name</th>
                    <th>Document Type</th>
                    <th>Uploaded Date</th>
                    <th>File</th>
                    <th>Status</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>John Doe</td>
                    <td><span class="fw-medium">Passport Copy</span></td>
                    <td>10 May 2024</td>
                    <td><a href="#" class="text-primary text-decoration-none small"><i class="bi bi-file-pdf me-1"></i> passport_main.pdf</a></td>
                    <td><span class="badge bg-success bg-opacity-10 text-success">Verified</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light border text-primary"><i class="bi bi-download"></i></button>
                        <button class="btn btn-sm btn-outline-light border text-danger"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
