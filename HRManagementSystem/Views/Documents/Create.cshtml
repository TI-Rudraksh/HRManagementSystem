@{
    ViewData["Title"] = "Upload Document";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Upload Document</h1>
            <p class="page-subtitle">Add employee records to the system</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">Upload Document</button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white p-4">
                    <h5 class="card-title fw-bold">Document Information</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-3">
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Select Employee</label>
                            <select class="form-select">
                                <option>Search Employee...</option>
                                <option>John Doe</option>
                                <option>Alice Smith</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Document Type</label>
                            <select class="form-select">
                                <option>Identity Proof</option>
                                <option>Education Certificate</option>
                                <option>Experience Letter</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Document Name</label>
                            <input type="text" class="form-control" placeholder="e.g. Passport Proof">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Upload File</label>
                            <input type="file" class="form-control">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
