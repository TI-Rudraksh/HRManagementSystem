@{
    ViewData["Title"] = "Add Appraisal";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Add Appraisal</h1>
            <p class="page-subtitle">Record and approve employee salary increments</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-graph-up-arrow me-2"></i> Approve Appraisal
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white p-4">
                    <h5 class="card-title fw-bold">Appraisal Information</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-3">
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Select Employee</label>
                            <select class="form-select">
                                <option>Search Employee...</option>
                                <option>John Doe</option>
                                <option>Alice Smith</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Current Salary</label>
                            <input type="text" class="form-control" value="$4,500" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Increment Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" placeholder="0.00">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Effective Date</label>
                            <input type="date" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Approved By</label>
                            <select class="form-select">
                                <option>Dhaval Patel (Admin)</option>
                                <option>HR Manager</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Remark (Optional)</label>
                            <textarea class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
