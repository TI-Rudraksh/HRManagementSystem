@{
    ViewData["Title"] = "Appraisals";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Appraisals</h1>
        <p class="page-subtitle">Manage employee salary increments</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-graph-up-arrow me-2"></i> Add Appraisal
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Employee Name</th>
                    <th class="text-center-align">Employee ID</th>
                    <th class="text-center-align">Old Salary</th>
                    <th class="text-center-align">Increment Amount</th>
                    <th class="text-center-align">New Salary</th>
                    <th>Effective Date</th>
                    <th>Approved By</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold shadow-sm" style="width: 38px; height: 38px;">
                                AS
                            </div>
                            <div>
                                <div class="fw-bold">Alice Smith</div>
                                <div class="small text-muted">Senior Developer</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-center-align">#102</td>
                    <td class="text-center-align fw-medium">$4,500</td>
                    <td class="text-center-align text-success">+$500</td>
                    <td class="text-center-align fw-bold text-dark">$5,000</td>
                    <td>01 Jun 2024</td>
                    <td><span class="small text-muted fw-medium">HR Manager</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-primary border"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-sm btn-outline-light text-danger border ms-2"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
