@{
    ViewData["Title"] = "Payroll";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Payroll</h1>
        <p class="page-subtitle">Manage employee salary processing</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-gear-fill me-2"></i> Generate Payroll
        </a>
    </div>
</div>

<div class="card mb-4 border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted small fw-bold">Month</span>
                    <input type="month" class="form-control border-start-0" value="@DateTime.Now.ToString("yyyy-MM")">
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select">
                    <option value="">All Departments</option>
                    <option>Engineering</option>
                    <option>Marketing</option>
                </select>
            </div>
            <div class="col-md-4">
                <select class="form-select">
                    <option value="">All Statuses</option>
                    <option>Paid</option>
                    <option>Unpaid</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Employee Name</th>
                    <th class="text-center-align">Employee ID</th>
                    <th>Department</th>
                    <th>Month</th>
                    <th class="text-center-align">Basic Salary</th>
                    <th class="text-center-align">Deductions</th>
                    <th class="text-center-align">Bonus</th>
                    <th class="text-center-align">Net Salary</th>
                    <th>Status</th>
                    <th>Payslip</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                JD
                            </div>
                            <div class="fw-bold small">John Doe</div>
                        </div>
                    </td>
                    <td class="text-center-align small">#101</td>
                    <td class="small">Engineering</td>
                    <td class="small">@DateTime.Now.ToString("MMMM yyyy")</td>
                    <td class="text-center-align fw-medium">$5,000</td>
                    <td class="text-center-align text-danger">$200</td>
                    <td class="text-center-align text-success">$500</td>
                    <td class="text-center-align fw-bold text-dark">$5,300</td>
                    <td><span class="badge bg-success bg-opacity-10 text-success">Paid</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary py-0 px-2" style="font-size: 0.75rem;">
                            <i class="bi bi-file-earmark-pdf me-1"></i> View
                        </button>
                    </td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-link text-muted p-0"><i class="bi bi-three-dots-vertical"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
