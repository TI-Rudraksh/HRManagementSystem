@{
    ViewData["Title"] = "Generate Payroll";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Generate Payroll</h1>
            <p class="page-subtitle">Process monthly salary for employees</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-gear-fill me-2"></i> Run Payroll
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Select Month</label>
                    <input type="month" class="form-control" value="@DateTime.Now.ToString("yyyy-MM")">
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Department</label>
                    <select class="form-select">
                        <option>All Departments</option>
                        <option>Engineering</option>
                        <option>HR</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-outline-primary w-100">Fetch Staff</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Employee</th>
                        <th class="text-center-align">Basic</th>
                        <th class="text-center-align">Bonus</th>
                        <th class="text-center-align">Deductions</th>
                        <th class="text-center-align">Net Payable</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="fw-bold">John Doe</div>
                            <div class="small text-muted">ID: #101</div>
                        </td>
                        <td class="text-center-align">
                            <input type="number" class="form-control form-control-sm text-center mx-auto" style="width: 100px;" value="5000">
                        </td>
                        <td class="text-center-align">
                            <input type="number" class="form-control form-control-sm text-center mx-auto" style="width: 80px;" value="0">
                        </td>
                        <td class="text-center-align">
                            <input type="number" class="form-control form-control-sm text-center mx-auto" style="width: 80px;" value="0">
                        </td>
                        <td class="text-center-align fw-bold text-primary">$5,000</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</form>
