@{
    ViewData["Title"] = "Edit User";
}

<form action="#" method="post">
    <!-- Page Header -->
    <div class="page-header border-bottom pb-4 mb-4">
        <div>
            <h1 class="page-title">Edit User</h1>
            <div class="breadcrumb-container">
                <div class="page-breadcrumb">
                    <a href="#">Dashboard</a> / <a href="@Url.Action("Index", "Users")">Users</a> / <span class="text-dark fw-medium">Edit User</span>
                </div>
            </div>
            <p class="page-subtitle mt-2 mb-0">Update user login account and modify role permissions</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a href="@Url.Action("Index", "Users")" class="btn btn-outline-secondary rounded-3 px-3 shadow-none border">Cancel</a>
            <button type="submit" class="btn btn-primary rounded-3 px-4 shadow-sm">
                Save User
            </button>
        </div>
    </div>

    <!-- Form Container -->
    <div class="card border-0 shadow-sm p-4 mx-auto" style="max-width: 900px;">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
            <h5 class="fw-semibold text-dark mb-0 fs-6">Account Details</h5>
            <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1 shadow-none" data-bs-toggle="modal" data-bs-target="#resetPasswordModal">
                <i class="bi bi-key"></i> Reset Password
            </button>
        </div>
        
        <div class="row g-4">
            <!-- Full Name -->
            <div class="col-md-6">
                <label class="form-label fw-medium text-dark small text-uppercase shadow-none border-0 px-0 ps-1 pb-1">Full Name</label>
                <input type="text" class="form-control px-3" value="Rudraksh Jani" required>
            </div>
            
            <!-- Email -->
            <div class="col-md-6">
                <label class="form-label fw-medium text-dark small text-uppercase shadow-none border-0 px-0 ps-1 pb-1">Email Address</label>
                <input type="email" class="form-control px-3" value="rudraksh@techies.com" required>
            </div>
            
            <!-- Role -->
            <div class="col-md-6">
                <label class="form-label fw-medium text-dark small text-uppercase shadow-none border-0 px-0 ps-1 pb-1">Role</label>
                <select class="form-select px-3" required>
                    <option value="Super Admin" selected>Super Admin</option>
                    <option value="Admin">Admin</option>
                    <option value="HR">HR</option>
                    <option value="Employee">Employee</option>
                </select>
            </div>

            <div class="col-12 mt-2 pt-3 border-top">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <label class="form-label fw-semibold text-dark mb-0 fs-6">User Status</label>
                        <div class="form-text mt-0">Toggle to activate or deactivate this user's login access.</div>
                    </div>
                    <div class="form-check form-switch ms-auto pt-2">
                        <input class="form-check-input" type="checkbox" id="statusSwitch" checked style="cursor: pointer; width: 3rem; height: 1.5rem;">
                        <label class="form-check-label ps-2 mt-1 text-dark fw-medium" for="statusSwitch">Active</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow border-0">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold fs-5" id="resetPasswordModalLabel">Reset User Password</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <form>
            <div class="mb-3">
                <label class="form-label text-dark fw-medium small text-uppercase shadow-none border-0 px-0 ps-1 pb-1">New Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" class="form-control border-start-0 ps-1" placeholder="Enter new password">
                </div>
            </div>
            <div class="mb-4 pb-2">
                <label class="form-label text-dark fw-medium small text-uppercase shadow-none border-0 px-0 ps-1 pb-1">Confirm Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" class="form-control border-start-0 ps-1" placeholder="Confirm new password">
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-1">
                <button type="button" class="btn btn-outline-secondary rounded-3 border px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-3 px-4 shadow-sm">Update Password</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>
