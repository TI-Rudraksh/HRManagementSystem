@{
    ViewData["Title"] = "Create Task";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Create Task</h1>
            <p class="page-subtitle">Assign a new task to an employee or team</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-send me-2"></i> Assign Task
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white p-4">
            <h5 class="card-title fw-bold">Task Information</h5>
        </div>
        <div class="card-body p-4 pt-0">
            <div class="row g-3 mb-3">
                <div class="col-md-12">
                    <label class="form-label small fw-bold">Task Title</label>
                    <input type="text" class="form-control" placeholder="Brief title of the task">
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Assign To</label>
                    <select class="form-select">
                        <option>Search Employee...</option>
                        <option>John Doe</option>
                        <option>Alice Smith</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Priority</label>
                    <select class="form-select">
                        <option>High</option>
                        <option selected>Medium</option>
                        <option>Low</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Due Date</label>
                    <input type="date" class="form-control" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-12">
                    <label class="form-label small fw-bold">Description</label>
                    <textarea class="form-control" rows="4" placeholder="Detailed instructions..."></textarea>
                </div>
                <div class="col-md-12">
                    <label class="form-label small fw-bold">Attachment (Optional)</label>
                    <input type="file" class="form-control">
                </div>
            </div>
        </div>
    </div>
</form>
