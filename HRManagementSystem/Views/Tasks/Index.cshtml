@{
    ViewData["Title"] = "Tasks";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Tasks</h1>
        <p class="page-subtitle">Assign and monitor employee tasks</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-square me-2"></i> Create Task
        </a>
    </div>
</div>

<div class="card mb-4 border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">Status</option>
                    <option>Todo</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">Priority</option>
                    <option>High</option>
                    <option>Medium</option>
                    <option>Low</option>
                </select>
            </div>
            <div class="col-md-4">
                <input type="text" class="form-control" placeholder="Search by employee...">
            </div>
            <div class="col-md-2 text-end">
                <button class="btn btn-outline-secondary w-100">Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Task Title</th>
                    <th>Assigned To</th>
                    <th>Assigned By</th>
                    <th class="text-center-align">Priority</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><div class="fw-bold">Quarterly Report Preparation</div></td>
                    <td>John Doe</td>
                    <td>Admin</td>
                    <td class="text-center-align"><span class="badge bg-danger">High</span></td>
                    <td>25 May 2024</td>
                    <td><span class="badge bg-info bg-opacity-10 text-info">In Progress</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-primary border"><i class="bi bi-eye"></i></button>
                    </td>
                </tr>
                <tr>
                    <td><div class="fw-bold">New Employee Onboarding</div></td>
                    <td>Alice Smith</td>
                    <td>Admin</td>
                    <td class="text-center-align"><span class="badge bg-success">Low</span></td>
                    <td>20 May 2024</td>
                    <td><span class="badge bg-success bg-opacity-10 text-success">Completed</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-secondary border"><i class="bi bi-eye"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
