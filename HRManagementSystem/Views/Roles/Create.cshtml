@{
    ViewData["Title"] = "Add Role";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Add Role</h1>
            <p class="page-subtitle">Define a new system access role</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">Create Role</button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white p-4">
                    <h5 class="card-title fw-bold">Role Details</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-3">
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Role Name</label>
                            <input type="text" class="form-control" placeholder="e.g. Sales Manager">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Description (Optional)</label>
                            <textarea class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
