@{
    ViewData["Title"] = "Assign Permission";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Assign Permission</h1>
            <p class="page-subtitle">Configure module level access for system roles</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">Update Permission</button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
                <div class="card-header bg-white p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Select Role</label>
                            <select class="form-select">
                                <option>HR Manager</option>
                                <option>Sales Head</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Module Name</th>
                                <th class="text-center">View</th>
                                <th class="text-center">Create</th>
                                <th class="text-center">Edit</th>
                                <th class="text-center">Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><b>Employee Management</b></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                            </tr>
                            <tr>
                                <td><b>Payroll & Salary</b></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                                <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>
