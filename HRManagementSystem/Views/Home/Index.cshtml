@inject HRManagementSystem.Data.DB _context

@{
    ViewData["Title"] = "Dashboard";
    var empCount = _context.Employees.Count();
    var activeCount = _context.Employees.Count(e => e.Emp_Status);
    var deptCount = _context.Departments.Count();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Welcome Back, Dhaval</h1>
        <p class="page-subtitle">Here is what is happening with your organization today.</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-outline-secondary me-2">
            <i class="bi bi-download me-2"></i> Export Report
        </button>
        <a asp-controller="Employee" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus me-2"></i> New Employee
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1">@empCount</h3>
                <p class="text-muted mb-0">Total Employees</p>
                <div class="mt-3 small">
                    <span class="text-success fw-medium"><i class="bi bi-arrow-up"></i> 12%</span>
                    <span class="text-muted ms-2">Since last month</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-person-check fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1">@activeCount</h3>
                <p class="text-muted mb-0">Active Employees</p>
                <div class="mt-3 small">
                    <span class="text-success fw-medium"><i class="bi bi-arrow-up"></i> 5%</span>
                    <span class="text-muted ms-2">Since last month</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-building fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1">@deptCount</h3>
                <p class="text-muted mb-0">Total Departments</p>
                <div class="mt-3 small">
                    <span class="text-muted">Stable organization</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-calendar2-check fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1">94%</h3>
                <p class="text-muted mb-0">Attendance Today</p>
                <div class="mt-3 small">
                    <span class="text-danger fw-medium"><i class="bi bi-arrow-down"></i> 2%</span>
                    <span class="text-muted ms-2">From yesterday</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-header bg-white p-4 border-bottom-0">
                <h5 class="card-title fw-bold">Recent Hires</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Employee</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th class="pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in _context.Employees.OrderByDescending(e => e.Emp_Id).Take(5))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 small fw-bold" style="width: 32px; height: 32px;">
                                            @emp.Emp_Name.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-medium text-dark">@emp.Emp_Name</div>
                                            <div class="small text-muted" style="font-size: 0.75rem;">ID: #@emp.Emp_Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="small">@(emp.Department?.DepartmentName ?? "General")</span>
                                </td>
                                <td>
                                    @if(emp.Emp_Status) {
                                        <span class="badge badge-active">Active</span>
                                    } else {
                                        <span class="badge badge-inactive">Inactive</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-controller="Employee" asp-action="Edit" asp-route-id="@emp.Emp_Id" class="btn btn-sm btn-light border">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-header bg-white p-4 border-bottom-0">
                <h5 class="card-title fw-bold">Quick Actions</h5>
            </div>
            <div class="card-body p-4 pt-0">
                <div class="d-grid gap-3">
                    <a href="#" class="btn btn-light border text-start p-3 d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div>
                            <div class="fw-medium text-dark">Generate Payslip</div>
                            <div class="small text-muted" style="font-size: 0.75rem;">Review and email payroll</div>
                        </div>
                    </a>
                    <a href="#" class="btn btn-light border text-start p-3 d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3">
                            <i class="bi bi-briefcase"></i>
                        </div>
                        <div>
                            <div class="fw-medium text-dark">Job Openings</div>
                            <div class="small text-muted" style="font-size: 0.75rem;">Manage active recruitments</div>
                        </div>
                    </a>
                    <a href="#" class="btn btn-light border text-start p-3 d-flex align-items-center">
                        <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <div class="fw-medium text-dark">Permission Audit</div>
                            <div class="small text-muted" style="font-size: 0.75rem;">Review security access logs</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
