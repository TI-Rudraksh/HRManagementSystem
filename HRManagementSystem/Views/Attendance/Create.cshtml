@{
    ViewData["Title"] = "Mark Attendance";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Mark Attendance</h1>
            <p class="page-subtitle">Select date and employees to record attendance</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Back to List</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-calendar-check me-2"></i> Submit Attendance
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white p-4">
            <h5 class="card-title fw-bold">Daily Attendance Details</h5>
        </div>
        <div class="card-body p-4 pt-0">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Attendance Date</label>
                    <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Department</label>
                    <select class="form-select">
                        <option>All Departments</option>
                        <option>Engineering</option>
                        <option>HR</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive border rounded">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                            <th>Employee</th>
                            <th>Status</th>
                            <th>Remark</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><input type="checkbox" class="form-check-input" checked></td>
                            <td>
                                <div class="fw-bold">John Doe</div>
                                <div class="small text-muted">ID: #101</div>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="status1" id="p1" checked>
                                        <label class="form-check-label small" for="p1">Present</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="status1" id="a1">
                                        <label class="form-check-label small" for="a1">Absent</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="status1" id="l1">
                                        <label class="form-check-label small" for="l1">Leave</label>
                                    </div>
                                </div>
                            </td>
                            <td><input type="text" class="form-control form-control-sm" placeholder="Optional remark"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</form>
