@{
    ViewData["Title"] = "Attendance";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Attendance</h1>
        <p class="page-subtitle">Track and manage employee attendance</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-calendar-check me-2"></i> Mark Attendance
        </a>
    </div>
</div>

<div class="card mb-4 border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Date</label>
                <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Department</label>
                <select class="form-select">
                    <option value="">All Departments</option>
                    <option>IT Department</option>
                    <option>HR Department</option>
                    <option>Sales</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Status</label>
                <select class="form-select">
                    <option value="">All Statuses</option>
                    <option>Present</option>
                    <option>Leave</option>
                    <option>Absent</option>
                    <option>Half Day</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-outline-secondary w-100">
                    <i class="bi bi-funnel me-2"></i> Apply Filters
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Employee Name</th>
                    <th class="text-center-align">Employee ID</th>
                    <th>Department</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Marked By</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 38px; height: 38px;">
                                JD
                            </div>
                            <div class="fw-bold">John Doe</div>
                        </div>
                    </td>
                    <td class="text-center-align">#101</td>
                    <td>IT Development</td>
                    <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                    <td><span class="badge bg-success bg-opacity-10 text-success">Present</span></td>
                    <td><span class="small text-muted">System Auto</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-primary border"><i class="bi bi-pencil"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 38px; height: 38px;">
                                AS
                            </div>
                            <div class="fw-bold">Alice Smith</div>
                        </div>
                    </td>
                    <td class="text-center-align">#102</td>
                    <td>HR Management</td>
                    <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                    <td><span class="badge bg-warning bg-opacity-10 text-warning">Half Day</span></td>
                    <td><span class="small text-muted">Admin</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-primary border"><i class="bi bi-pencil"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 38px; height: 38px;">
                                BM
                            </div>
                            <div class="fw-bold">Bob Martin</div>
                        </div>
                    </td>
                    <td class="text-center-align">#103</td>
                    <td>Sales</td>
                    <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                    <td><span class="badge bg-danger bg-opacity-10 text-danger">Absent</span></td>
                    <td><span class="small text-muted">-</span></td>
                    <td class="actions-column">
                        <button class="btn btn-sm btn-outline-light text-primary border"><i class="bi bi-pencil"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
