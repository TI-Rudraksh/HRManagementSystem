@{
    ViewData["Title"] = "Add Reimbursement";
}

<form>
    <div class="page-header">
        <div>
            <h1 class="page-title">Submit Reimbursement</h1>
            <p class="page-subtitle">Process employee expense claims</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-cash-stack me-2"></i> Submit Request
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white p-4">
                    <h5 class="card-title fw-bold">Reimbursement Request Detail</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-4">
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Select Employee</label>
                            <select class="form-select">
                                <option>Search Employee...</option>
                                <option>John Doe</option>
                                <option>Alice Smith</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Reimbursement Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" placeholder="000.00">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Category</label>
                            <select class="form-select">
                                <option>Travel Allowance</option>
                                <option>Medical Expense</option>
                                <option>Food & Allowance</option>
                                <option>Training & Development</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Submission Date</label>
                            <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label small fw-bold text-muted">Bill Attachment (JPG/PNG/PDF)</label>
                            <input type="file" class="form-control">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
